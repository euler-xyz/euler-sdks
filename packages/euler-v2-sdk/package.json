{
  "name": "euler-v2-sdk",
  "version": "1.0.0",
  "description": "Minimal TypeScript npm package template (ESM, NodeNext)",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "typescript",
    "node",
    "boilerplate",
    "esm",
    "npm-package"
  ],
  "license": "MIT",
  "dependencies": {
    "viem": "^2.43.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
