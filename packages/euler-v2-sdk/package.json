{
  "name": "euler-v2-sdk",
  "version": "0.0.12-alpha",
  "description": "SDK for interacting with Euler V2 Lending Platform",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/euler-xyz/euler-sdks.git",
    "directory": "packages/euler-v2-sdk"
  },
  "homepage": "https://github.com/euler-xyz/euler-sdks/tree/main/packages/euler-v2-sdk",
  "bugs": {
    "url": "https://github.com/euler-xyz/euler-sdks/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json",
    "./AGENTS.md": "./AGENTS.md",
    "./skills/*": "./skills/*"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "skills"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "release:check": "pnpm run clean && pnpm run build && pnpm run typecheck && pnpm pack --dry-run",
    "prepublishOnly": "pnpm run release:check",
    "publish:public": "npm publish --access public --provenance",
    "anvil": "source examples/.env && anvil --fork-url $FORK_RPC_URL --auto-impersonate"
  },
  "keywords": [
    "euler",
    "defi",
    "lending",
    "ethereum",
    "evm",
    "sdk",
    "typescript",
    "viem"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "viem": "^2.43.3"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "@types/node": "^22.7.8",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
