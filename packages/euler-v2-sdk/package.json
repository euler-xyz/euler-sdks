{
  "name": "@eulerxyz/euler-v2-sdk",
  "version": "0.1.0-beta",
  "description": "SDK for interacting with Euler V2 Lending Platform",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/euler-xyz/euler-sdks.git",
    "directory": "packages/euler-v2-sdk"
  },
  "homepage": "https://github.com/euler-xyz/euler-sdks/tree/main/packages/euler-v2-sdk",
  "bugs": {
    "url": "https://github.com/euler-xyz/euler-sdks/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "format": "biome format --write src",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "prepare": "cd ../.. && if command -v husky >/dev/null 2>&1; then husky packages/euler-v2-sdk/.husky; fi",
    "clean": "rm -rf dist",
    "release:check": "pnpm run clean && pnpm run build && pnpm run typecheck && pnpm pack --dry-run",
    "prepublishOnly": "pnpm run release:check",
    "publish:public": "npm publish --access public --provenance"
  },
  "keywords": [
    "euler",
    "defi",
    "lending",
    "ethereum",
    "evm",
    "sdk",
    "typescript",
    "viem"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "viem": "2.43.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.8",
    "typescript": "^5.6.3"
  }
}
