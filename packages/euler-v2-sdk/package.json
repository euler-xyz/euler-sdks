{
  "name": "euler-v2-sdk",
  "version": "1.0.0",
  "description": "SDK for interacting with Euler V2 Lending Platform",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "deposit-example": "tsx examples/execution/deposit-example",
    "mint-example": "tsx examples/execution/mint-example",
    "withdraw-example": "tsx examples/execution/withdraw-example",
    "redeem-example": "tsx examples/execution/redeem-example",
    "borrow-example": "tsx examples/execution/borrow-example",
    "repay-from-wallet-example": "tsx examples/execution/repay-from-wallet-example",
    "repay-from-deposit-example": "tsx examples/execution/repay-from-deposit-example",
    "repay-with-swap-example": "tsx examples/execution/repay-with-swap-example",
    "multiply-example": "tsx examples/execution/multiply-example",
    "swap-collateral-example": "tsx examples/execution/swap-collateral-example",
    "swap-debt-example": "tsx examples/execution/swap-debt-example",
    "transfer-example": "tsx examples/execution/transfer-example",
    "pull-debt-example": "tsx examples/execution/pull-debt-example",
    "liquidation-example": "tsx examples/execution/liquidation-example",
    "merge-plans-example": "tsx examples/execution/merge-plans-example",
    "fetch-apys-example": "tsx examples/vaults/fetch-apys-example",
    "anvil": "source examples/.env && anvil --fork-url $FORK_RPC_URL --auto-impersonate",
    "examples": "./run-examples.sh"
  },
  "keywords": [
    "typescript",
    "node",
    "boilerplate",
    "esm",
    "npm-package"
  ],
  "license": "MIT",
  "dependencies": {
    "viem": "^2.43.3"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "@types/node": "^22.7.8",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
