{
  "name": "euler-v2-sdk",
  "version": "1.0.0",
  "description": "SDK for interacting with Euler V2 Lending Platform",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "deposit-example": "tsx examples/deposit-example",
    "multiply-example": "tsx examples/multiply-example",
    "repay-with-swap-example": "tsx examples/repay-with-swap-example",
    "anvil": "source examples/.env && anvil --fork-url $FORK_RPC_URL --auto-impersonate"
  },
  "keywords": [
    "typescript",
    "node",
    "boilerplate",
    "esm",
    "npm-package"
  ],
  "license": "MIT",
  "dependencies": {
    "viem": "^2.43.3"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "@types/node": "^22.7.8",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
